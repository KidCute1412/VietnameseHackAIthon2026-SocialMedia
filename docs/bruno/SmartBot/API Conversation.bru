meta {
  name: API Conversation
  type: http
  seq: 1
}

post {
  url: https://assistant-stream.vnpt.vn/v1/conversation
  body: json
  auth: inherit
}

headers {
  Authorization: Bearer {{accessToken}}
  Token-id: {{token-id}}
  Token-key: {{token-key}}
  Content-Type: application/json
}

body:json {
  {
    "bot_id": "{{bot_id}}",
    "sender_id": "abc",
    "text": "Chương trình Hackathon có gì đặc biệt" ,
    "input_channel": "livechat",
    "session_id": "123",
    "metadata": {"button_variables": []}
  }
  
}

settings {
  encodeUrl: true
}
