# API configuration for HypeRoom

# Tavily Search
TAVILY_API_KEY=your_tavily_api_key_here

# Redis Queue (Upstash)
REDIS_URL=rediss://default:password@your-upstash-endpoint:6379

# VNPT SmartReader / SmartVoice
VNPT_TOKEN_ID=your_vnpt_token_id
VNPT_TOKEN_KEY=your_vnpt_token_key
VNPT_AUTHORIZATION=Bearer your_vnpt_access_token
VNPT_MAC_ADDRESS=EGOV-DIGDOC-WEB-API
VNPT_CLIENT_SESSION=hyperoom-manual-ingestion
VNPT_SMARTREADER_BODY_TOKEN=your_smartreader_body_token

# VNPT SmartBot
VNPT_SMARTBOT_API_URL=https://api.vnpt.vn/smartbot/v2/chat
VNPT_SMARTBOT_TOKEN=your_vnpt_token_here
VNPT_SMARTBOT_ID=bot_hyperoom_assistant_01
