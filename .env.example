# Cấu hình API key cho hệ thống HypeRoom
# Tạo tệp .env cùng cấp và sao chép nội dung dưới đây, điền key tương ứng.

# API Key cho dịch vụ truy xuất chứng cứ trực tuyến (Tavily Search)
TAVILY_API_KEY=your_tavily_api_key_here

# API Key / URL cho VNPT SmartBot (Nếu sử dụng môi trường thật)
VNPT_SMARTBOT_API_URL=https://api.vnpt.vn/smartbot/v2/chat
VNPT_SMARTBOT_TOKEN=your_vnpt_token_here
VNPT_SMARTBOT_ID=bot_hyperoom_assistant_01
